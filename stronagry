<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Moje Gry</title>
<style>
body { font-family: Arial; text-align: center; background: #111; color: #fff; }
button { padding: 10px 20px; margin: 10px; font-size: 16px; cursor: pointer; }
.game { display: none; margin-top: 20px; }
canvas { background: #000; }
</style>
</head>
<body>
<h1>🎮 Moje Gry</h1>

<!-- 🔽 CLICKER (OBRAZEK POD PRZYCISKIEM) -->
<div style="display:inline-block;">
  <button onclick="showGame('clicker')">Clicker</button><br>
  <img src="https://imgs.crazygames.com/click-click-clicker_16x9/20240206102255/click-click-clicker_16x9-cover?metadata=none&quality=60&height=4300"
       width="120"
       style="display:block; margin:5px auto;">
</div>

<div style="display:inline-block;">
  <button onclick="showGame('guess')">Zgadnij Liczbę</button><br>
  <img src="https://play-lh.googleusercontent.com/Ud24UigX7HQG_AhBCnChWFsuXAVXCScGPA1CUa2O6Q7oq6w31xpP3A_24hVqZvOvQWE"
       width="120"
       style="display:block; margin:5px auto;">
</div>

<div style="display:inline-block;">
  <button onclick="startSnake()">Snake</button><br>
  <img src="https://www.coolmathgames.com/sites/default/files/Snake_OG-logo.jpg" width="120" style="display:block; margin:5px auto;">
</div>

<div style="display:inline-block;">
  <button onclick="startFlappy()">Flappy Bird</button><br>
  <img src="https://i.ytimg.com/vi/LWcP4vM1KEQ/maxresdefault.jpg"
       width="120"
       style="display:block; margin:5px auto;">
</div>

<div id="clicker" class="game">
  <h2>Clicker</h2>
  <p>Punkty: <span id="clickScore">0</span></p>
  <button onclick="addPoint()">Kliknij!</button>
</div>

<div id="guess" class="game">
  <h2>Zgadnij Liczbę (1-100)</h2>
  <input type="number" id="guessInput">
  <button onclick="checkGuess()">Sprawdź</button>
  <p id="guessResult"></p>
</div>

<div id="snake" class="game">
  <h2>Snake</h2>
  <p>🎮 Sterowanie: W A S D</p>
  <button onclick="startSnake()">Start / Restart</button>
  <p id="snakeScore">Punkty: 0</p>
  <canvas id="game" width="300" height="300"></canvas>
</div>

<div id="flappy" class="game">
  <h2>Flappy Bird</h2>
  <button onclick="startFlappy()">Start / Restart</button>
  <p id="flappyScore">Punkty: 0</p>
  <canvas id="flappyCanvas" width="300" height="300"></canvas>
</div>

<script>

// zatrzymanie wszystkich gier
function stopAllGames(){
  if(loop) clearInterval(loop);
  if(fbLoop) clearInterval(fbLoop);
  flappyRunning = false;
}

function showGame(id){
  stopAllGames();
  document.querySelectorAll('.game').forEach(g=>g.style.display='none');
  document.getElementById(id).style.display='block';
}

// Clicker
let clickScore=0;
function addPoint(){
  clickScore++;
  document.getElementById('clickScore').innerText=clickScore;
}

// Zgadnij liczbę
let number=Math.floor(Math.random()*100)+1;
function checkGuess(){
  let g=Number(document.getElementById('guessInput').value);
  let r=document.getElementById('guessResult');
  if(g===number){r.innerText='Brawo!';}
  else if(g<number){r.innerText='Za mało';}
  else{r.innerText='Za dużo';}
}

// Snake
let snake,dx,dy,food,score,loop,ctx;
function startSnake(){
  stopAllGames();
  showGame('snake');

  const canvas=document.getElementById('game');
  ctx=canvas.getContext('2d');
  snake=[{x:150,y:150}]; dx=10; dy=0; score=0;
  document.getElementById('snakeScore').innerText='Punkty: 0';
  food=randomFood();

  loop=setInterval(gameLoop,100);
}
function randomFood(){ return {x:Math.floor(Math.random()*30)*10,y:Math.floor(Math.random()*30)*10}; }

document.addEventListener('keydown',e=>{
  if((e.key==='w' || e.key==='W') && dy===0){dx=0;dy=-10;}
  if((e.key==='s' || e.key==='S') && dy===0){dx=0;dy=10;}
  if((e.key==='a' || e.key==='A') && dx===0){dx=-10;dy=0;}
  if((e.key==='d' || e.key==='D') && dx===0){dx=10;dy=0;}
});

function gameLoop(){
  ctx.clearRect(0,0,300,300);
  let head={x:snake[0].x+dx,y:snake[0].y+dy};
  if(head.x<0||head.x>=300||head.y<0||head.y>=300){gameOver();return;}
  for(let p of snake){ if(p.x===head.x && p.y===head.y){gameOver();return;} }
  snake.unshift(head);
  if(head.x===food.x && head.y===food.y){ score++; document.getElementById('snakeScore').innerText='Punkty: '+score; food=randomFood(); }
  else snake.pop();
  ctx.fillStyle='red'; ctx.fillRect(food.x,food.y,10,10);
  ctx.fillStyle='lime'; snake.forEach(p=>ctx.fillRect(p.x,p.y,10,10));
}
function gameOver(){ clearInterval(loop); alert('💀 Przegrałeś! Wynik: '+score); }

// Flappy
let fbCtx, birdY, velocity, gravity, pipes, fbLoop, fbScore, flappyRunning=false;
let birdImg = new Image();
birdImg.src = "https://www.pngall.com/wp-content/uploads/15/Flappy-Bird-PNG-Photos.png";

function startFlappy(){
  stopAllGames();
  showGame('flappy');

  const c=document.getElementById('flappyCanvas');
  fbCtx=c.getContext('2d');

  birdY=150;
  velocity=0;
  gravity=0.5;
  pipes=[];
  fbScore=0;
  flappyRunning=true;

  document.getElementById('flappyScore').innerText='Punkty: 0';

  fbLoop=setInterval(fbGame,20);
}

const flappyCanvas = document.getElementById('flappyCanvas');
flappyCanvas.addEventListener('mousedown', ()=>{
  if(flappyRunning){
    velocity = -8;
  }
});

function fbGame(){
  if(!flappyRunning) return;

  fbCtx.clearRect(0,0,300,300);

  velocity += gravity;
  birdY += velocity;

  fbCtx.drawImage(birdImg, 50, birdY, 30, 30);

  if(pipes.length===0 || pipes[pipes.length-1].x < 180){
    let gap = 90;
    let top = Math.random()*120 + 20;
    pipes.push({x:300, top:top, bottom:top+gap, passed:false});
  }

  pipes.forEach(p=>{
    p.x -= 2;

    fbCtx.fillStyle='green';
    fbCtx.fillRect(p.x,0,30,p.top);
    fbCtx.fillRect(p.x,p.bottom,30,300-p.bottom);

    const hitboxOffset = 5;
    let birdLeft = 50 + hitboxOffset;
    let birdRight = 80 - hitboxOffset;
    let birdTop = birdY + hitboxOffset;
    let birdBottom = birdY + 30 - hitboxOffset;

    if(birdRight > p.x && birdLeft < p.x + 30){
      if(birdTop < p.top || birdBottom > p.bottom){
        fbEnd();
      }
    }

    if(!p.passed && p.x < 50){
      p.passed=true;
      fbScore++;
      document.getElementById('flappyScore').innerText='Punkty: '+fbScore;
    }
  });

  pipes = pipes.filter(p=>p.x>-30);

  if(birdY < 0 || birdY > 270){
    fbEnd();
  }
}

function fbEnd(){
  flappyRunning=false;
  clearInterval(fbLoop);
  alert('💀 Przegrałeś! Wynik: '+fbScore);
}

</script>
</body>
</html>